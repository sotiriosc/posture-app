{
  "name": "praxis",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/consumer",
    "build": "npm run build --workspace=apps/consumer",
    "start": "npm run start --workspace=apps/consumer",
    "lint": "eslint",
    "test": "vitest",
    "test:benchmark": "vitest --run packages/engine/tests/unit/competitiveBenchmark.test.ts",
    "test:golden": "vitest --run packages/engine/tests/unit/programGoldenAnchors.test.ts packages/engine/tests/unit/programIdentityAnchors.test.ts packages/engine/tests/unit/questionnaireGoldenFlow.test.ts",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test --config=apps/consumer/playwright.config.ts",
    "test:critical": "vitest run --config packages/engine/vitest.config.ts packages/engine/tests/unit/programGoldenAnchors.test.ts packages/engine/tests/unit/programIdentityAnchors.test.ts packages/engine/tests/unit/questionnaireGoldenFlow.test.ts packages/engine/tests/unit/programDeterminism.test.ts packages/engine/tests/unit/competitiveBenchmark.test.ts packages/engine/tests/unit/catalogLadderInvariants.test.ts packages/engine/tests/unit/stripeWebhookLogic.test.ts packages/engine/tests/unit/stripeWebhookVerification.test.ts packages/engine/tests/unit/mergeReadinessAnchors.test.ts packages/engine/tests/unit/feedbackContractModify.test.ts packages/engine/tests/unit/feedbackContractSacrifice.test.ts packages/engine/tests/unit/feedbackContractSuppression.test.ts packages/engine/tests/unit/feedbackContractTest.test.ts packages/engine/tests/unit/ladderAdvancementCriteria.test.ts packages/engine/tests/unit/ladderAdvancementDeterminism.test.ts packages/engine/tests/unit/ladderSafetyFloor.test.ts packages/engine/tests/unit/ladderVariationConstraint.test.ts packages/engine/tests/unit/phaseGatingDeterminism.test.ts packages/engine/tests/unit/programPhaseProgressionCoherence.test.ts packages/engine/tests/unit/programProgressionTransition.test.ts packages/engine/tests/unit/progression.test.ts packages/engine/tests/unit/accountIsolation.test.ts packages/engine/tests/unit/coachNoteStore.test.ts packages/engine/tests/unit/focusSentence.test.ts packages/engine/tests/unit/offlineSyncQueue.test.ts packages/engine/tests/unit/subscriptionStore.test.ts",
    "test:full": "vitest --run --config packages/engine/vitest.config.ts",
    "test:full:gyms": "vitest --run --config apps/gyms/vitest.config.ts",
    "test:full:consumer": "vitest --run --config apps/consumer/vitest.config.ts",
    "test:e2e:smoke:consumer": "cd apps/consumer && playwright test tests/e2e/firstRunHappyPath.spec.ts tests/e2e/perAccountStateIsolation.spec.ts",
    "test:e2e:smoke:gyms": "cd apps/gyms && PLAYWRIGHT_PORT=3100 playwright test tests/e2e/firstRunHappyPath.spec.ts tests/e2e/perAccountStateIsolation.spec.ts",
    "test:engine": "node --import tsx packages/engine/src/__debug__/engineMatrixTest.ts",
    "audit:catalog": "node --import tsx packages/engine/src/__debug__/catalogAudit.ts",
    "audit:store": "node --import tsx packages/engine/src/__debug__/storeIntegritySmoke.ts",
    "audit:phase-matrix": "node --import tsx packages/engine/src/__debug__/phaseMatrixProgramPrint.ts",
    "audit:coverage-matrix": "node --import tsx packages/engine/src/__debug__/coverageContractAudit.ts",
    "audit:program-contract": "node --import tsx packages/engine/src/__debug__/programContractAudit.ts",
    "audit:decision-trace": "node --import tsx packages/engine/src/__debug__/decisionTraceAudit.ts",
    "debug:program": "node --import tsx packages/engine/src/__debug__/printProgram.ts",
    "smoke:photo-ns": "node --import tsx packages/engine/src/__debug__/photoNamespaceSmoke.ts",
    "smoke:phase": "node --import tsx packages/engine/src/__debug__/phaseEligibilitySmoke.ts"
  },
  "dependencies": {
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.20.0",
    "@types/pg": "^8.16.0",
    "next": "^16.2.11",
    "next-plausible": "^4.0.0",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
