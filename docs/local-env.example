# Copy these values into .env.local for DB-free local development.
# This mode does not use Neon/Postgres.

USER_STORE_DRIVER=memory
TRAINING_STORE_DRIVER=disabled
DATABASE_URL=
APP_URL=http://localhost:3000

# Optional local auth bootstrap. Use local-only values.
AUTH_SECRET=replace-with-local-dev-secret
AUTH_USER_EMAIL=local@example.com
AUTH_USER_PASSWORD=replace-with-local-password
AUTH_USER_PLAN=free

# Optional local admin gate.
ADMIN_ACCESS_KEY=replace-with-local-admin-key

# Optional Stripe test-mode values only when testing billing locally.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
