{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/lib/*": ["./packages/engine/src/*"],
      "@/*": ["./apps/consumer/src/*"],
      "@praxis/engine": ["./packages/engine/src/index.ts"],
      "@praxis/engine/*": ["./packages/engine/src/*"]
    }
  },
  "include": [
    "packages/engine/src/**/*.ts",
    "packages/engine/src/**/*.js",
    "packages/engine/tests/**/*.ts",
    "apps/consumer/src/**/*.ts",
    "apps/consumer/src/**/*.tsx",
    "apps/consumer/**/*.ts",
    "apps/consumer/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "packages/engine/src/__debug__/**"
  ]
}
